<view class="container">
  <!-- 未绑定状态：只显示扫码按钮 -->
  <block wx:if="{{!hasBinding}}">
    <button class="btn bind-btn" bindtap="scanCode">扫码绑定</button>
  </block>

  <!-- 已绑定状态：显示排队信息 -->
  <block wx:else>
    <view class="header">
      <text class="title">{{activityName}}</text>
      <text class="subtitle">排队状态</text>
    </view>
    
    <view class="status-card">
      <view class="status-item">
        <text class="label">活动名称</text>
        <text class="value">{{activityName}}</text>
      </view>
      <view class="status-item">
        <text class="label">手环号码</text>
        <text class="value">{{braceletId}}</text>
      </view>
      <view class="status-item">
        <text class="label">您的号码</text>
        <text class="value highlight">{{userNumber}}</text>
      </view>
      <view class="status-item">
        <text class="label">前方还有</text>
        <text class="value highlight">{{queueCount}} 人</text>
      </view>
    </view>
    
    <view class="actions">
      <button class="btn primary-btn" bindtap="refreshStatus">刷新状态</button>
      <button class="btn secondary-btn" bindtap="scanCode">重新绑定</button>
    </view>
  </block>
</view>