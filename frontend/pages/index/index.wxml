<view class="container" bindtap="handleGlobalClick">
  <!-- 背景图容器 -->
  <view class="background-container">
    <!-- 白色背景层 -->
    <view class="white-background"></view>
    <!-- PNG 图片 -->
    <image class="background-image" src="/xiaochengxu_compressed.jpg" mode="widthFix"></image>
  </view>
  <!-- 右上角头像入口 -->
  <view class="user-center-btn" bindtap="goToUserCenter" catchtap="goToUserCenter">
    <view class="user-icon">
      <image wx:if="{{userAvatar}}" class="avatar-img" src="{{userAvatar}}" />
      <text wx:else class="icon-text">👤</text>
    </view>
  </view>
  
  <!-- 未授权状态提示 -->
  <view wx:if="{{!hasAuth}}" class="unauth-hint">
    <text class="hint-text">点击任意区域授权后获取完整服务</text>
  </view>
  
  <!-- 已授权状态：显示用户信息 -->
  <view wx:else class="auth-content">
    <view class="user-info">
      <text class="welcome-text">欢迎回来，{{userNickName || '用户'}}</text>
    </view>
  </view>

  <!-- 已绑定手环横幅：与「我的绑定」同源计数，点击查看排队进度 -->
  <view wx:if="{{hasAuth && showBindingBanner}}" class="binding-banner-wrap" catchtap="goToMyBindings">
    <view class="binding-banner-inner">
      <view class="binding-banner-texts">
        <text class="binding-banner-title">当前已绑定 {{boundBraceletCount}} 个手环码</text>
        <text class="binding-banner-sub">点击查看排队进度</text>
      </view>
      <text class="binding-banner-arrow">›</text>
    </view>
  </view>
  
  <!-- 底部绑定手环码按钮（所有状态都显示） -->
  <view class="bind-button-container">
    <button class="bind-button" bindtap="handleBindBracelet">点击绑定手环码</button>
  </view>
  
  <!-- 授权弹窗：昵称和头像填写表单 -->
  <view wx:if="{{showAuthModal2}}" class="modal-mask">
    <view class="modal-container auth-form-modal" catchtap="onModalContainerTap">
      <view class="modal-body auth-form-body">
        <!-- 头像选择 -->
        <view class="avatar-section">
          <button 
            class="avatar-btn"
            open-type="chooseAvatar"
            bindchooseavatar="onChooseAvatar"
          >
            <image wx:if="{{tempAvatar}}" class="avatar-circle" src="{{tempAvatar}}" />
            <view wx:else class="avatar-default">
              <text class="avatar-icon">👤</text>
            </view>
          </button>
          <text class="avatar-tip">点击更换头像</text>
        </view>
        
        <!-- 昵称填写 -->
        <view class="nickname-section">
          <input 
            class="nickname-input" 
            type="nickname"
            placeholder="请输入昵称" 
            value="{{tempNickName}}" 
            bindblur="onNickNameBlur"
            bindinput="onNickNameInput"
          />
        </view>
      </view>
      <view class="modal-footer auth-form-footer">
        <button class="btn cancel-btn" bindtap="closeAuthModal2">取消</button>
        <button 
          class="btn confirm-btn" 
          bindtap="submitAuthForm" 
          disabled="{{!tempNickName || !tempAvatar}}"
        >
          确认授权
        </button>
      </view>
    </view>
  </view>
</view>