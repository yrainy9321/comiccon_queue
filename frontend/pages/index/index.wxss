/* index.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bind-btn {
  width: 80%;
  max-width: 500rpx;
  height: 90rpx;
  background-color: #1989fa;
  color: #fff;
  font-size: 36rpx;
  border-radius: 45rpx;
  box-shadow: 0 4rpx 12rpx rgba(25, 137, 250, 0.3);
}

/* 排队状态卡片样式 */
.header {
  text-align: center;
  margin-bottom: 60rpx;
  padding-top: 60rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
}

.status-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin: 20rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.status-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.status-item:last-child {
  border-bottom: none;
}

.status-item .label {
  font-size: 28rpx;
  color: #666;
}

.status-item .value {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.status-item .value.highlight {
  color: #1989fa;
  font-weight: bold;
  font-size: 36rpx;
}

.actions {
  margin: 40rpx 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn {
  width: 100%;
  max-width: 500rpx;
  height: 90rpx;
  font-size: 32rpx;
  border-radius: 45rpx;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.primary-btn {
  background-color: #1989fa;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(25, 137, 250, 0.3);
}

.secondary-btn {
  background-color: #fff;
  color: #1989fa;
  border: 2rpx solid #1989fa;
}