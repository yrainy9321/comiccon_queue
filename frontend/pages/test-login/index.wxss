/* test-login/index.wxss */
.container {
  padding: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
}

.card {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.status-item {
  margin-bottom: 30rpx;
  display: flex;
  align-items: flex-start;
  flex-wrap: wrap;
}

.status-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #666;
  min-width: 140rpx;
}

.value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

.value.success {
  color: #52c41a;
  font-weight: bold;
}

.value.pending {
  color: #faad14;
}

.value.openid {
  font-family: 'Courier New', monospace;
  font-size: 24rpx;
  color: #1890ff;
}

.value.token {
  font-family: 'Courier New', monospace;
  font-size: 20rpx;
  color: #999;
}

.hint {
  font-size: 22rpx;
  color: #999;
  margin-left: 10rpx;
}

.actions {
  margin-bottom: 30rpx;
}

.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  margin-bottom: 20rpx;
  border: none;
}

.btn.primary {
  background: white;
  color: #667eea;
  font-weight: bold;
}

.btn.secondary {
  background: rgba(255, 255, 255, 0.2);
  color: white;
  border: 2rpx solid white;
}

.btn[disabled] {
  opacity: 0.6;
}

.tips {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 30rpx;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.tip-item {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 10rpx;
}
