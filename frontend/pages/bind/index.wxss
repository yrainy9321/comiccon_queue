/* bind.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
  padding-top: 60rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
}

.scan-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 60rpx;
}

.scan-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.scan-text {
  font-size: 28rpx;
  color: #666;
}

.scan-btn {
  width: 100%;
  max-width: 500rpx;
  height: 90rpx;
  background-color: #1989fa;
  color: #fff;
  font-size: 36rpx;
  border-radius: 45rpx;
  margin: 0 auto 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(25, 137, 250, 0.3);
}

.tips {
  background-color: #f0f9ff;
  border-radius: 12rpx;
  padding: 30rpx;
  border-left: 8rpx solid #1989fa;
  margin-bottom: 40rpx;
}

.tip-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.tip-content {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
}