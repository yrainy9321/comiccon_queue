/* 浅灰底 + 白卡片，贴近微信设置/表单页 */
.page {
  min-height: 100vh;
  padding-bottom: 48rpx;
  background-color: #ededed;
  box-sizing: border-box;
}

.group {
  margin-top: 24rpx;
  background-color: #fff;
}

.group:first-child {
  margin-top: 0;
}

.cell {
  padding: 24rpx 32rpx;
  font-size: 34rpx;
}

.cell-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cell-title {
  color: #000;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.cell-bd {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  min-height: 48rpx;
}

.cell-value {
  text-align: right;
}

.cell-value.is-ph {
  color: #888;
}

.cell-value.is-on {
  color: #000;
}

.cell-accessory {
  margin-left: 8rpx;
  color: #c7c7cc;
  font-size: 36rpx;
  line-height: 1;
}

.cell-input-row {
  display: flex;
  align-items: center;
}

.cell-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  font-size: 34rpx;
}

.cell-btn-mini {
  margin-left: 16rpx;
  flex-shrink: 0;
}

.queue-input {
  width: 100%;
  height: 72rpx;
  font-size: 34rpx;
  box-sizing: border-box;
}

.hint {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #888;
}

.footer {
  margin: 48rpx 32rpx 0;
}

.footer button[type="primary"] {
  width: 100%;
}

.recent-group {
  margin: 24rpx 24rpx 0;
  border-radius: 16rpx;
  overflow: hidden;
}

.recent-title {
  padding: 24rpx 28rpx 8rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.recent-empty {
  padding: 24rpx 28rpx 30rpx;
  color: #888;
  font-size: 26rpx;
}

.recent-list {
  padding: 12rpx 20rpx 20rpx;
}

.recent-card {
  background: #fafafa;
  border: 1rpx solid #eee;
  border-radius: 14rpx;
  padding: 20rpx 22rpx;
  margin-bottom: 16rpx;
}

.recent-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 10rpx;
  gap: 16rpx;
}

.recent-act {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 600;
  color: #1a1a1a;
}

.recent-unbind {
  margin: 0;
  min-width: 100rpx;
  height: 52rpx;
  line-height: 52rpx;
  font-size: 24rpx;
  padding: 0 16rpx;
}

.recent-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  border-bottom: 1rpx solid #efefef;
  padding: 12rpx 0;
  gap: 20rpx;
}

.recent-row.last {
  border-bottom: none;
}

.recent-k {
  width: 170rpx;
  flex-shrink: 0;
  color: #888;
  font-size: 24rpx;
}

.recent-v {
  flex: 1;
  text-align: right;
  color: #333;
  font-size: 26rpx;
  word-break: break-all;
}

.recent-v.mono {
  font-family: ui-monospace, Menlo, monospace;
  font-size: 23rpx;
}

.recent-v.num {
  font-size: 30rpx;
  font-weight: 600;
  color: #1677ff;
}

.recent-v.st-waiting {
  color: #1677ff;
}

.recent-v.st-claimed {
  color: #d48806;
}

.recent-v.st-called {
  color: #389e0d;
}
