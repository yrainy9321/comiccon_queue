<view class="page">
  <view wx:if="{{loading}}" class="state">加载中…</view>

  <block wx:elif="{{empty}}">
    <view class="empty-wrap">
      <text class="empty-title">暂无绑定记录</text>
      <text class="empty-sub">领取手环后将在此展示排队号码与等候信息</text>
    </view>
  </block>

  <scroll-view
    wx:else
    class="list"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
  >
    <view
      wx:for="{{list}}"
      wx:key="rowKey"
      class="card"
    >
      <view class="card-top">
        <text class="act-name">{{item.activityName || '未命名活动'}}</text>
        <text class="claim-time">领取时间 {{item.userScanBoundText}}</text>
      </view>

      <view class="number-block">
        <text class="number-label">我的号码</text>
        <text class="queue-number">{{item.queueNumber}}</text>
      </view>

      <view class="rule-line">
        <view class="rule-dot" />
        <view class="rule-dot" />
        <view class="rule-dot" />
      </view>

      <view class="ahead-wrap" wx:if="{{item.showAhead}}">
        <view class="ahead-bar">
          <block wx:if="{{item.aheadParts}}">
            <text class="ahead-txt">{{item.aheadParts.pre}}</text>
            <text class="ahead-num">{{item.aheadParts.num}}</text>
            <text class="ahead-txt">{{item.aheadParts.post}}</text>
          </block>
          <text wx:else class="ahead-plain">{{item.aheadLine}}</text>
        </view>
      </view>

      <view class="queue-status-wrap">
        <view wx:if="{{item.queueStateKind === 'normal'}}" class="wait-panel">
          <view class="wait-head">
            <text class="wait-title">预计等待时间</text>
          </view>
          <view class="wait-value-shell">
            <view wx:if="{{item.etaMinutes != null}}" class="wait-row">
              <text class="wait-pre">约</text>
              <text class="wait-mid">{{item.etaMinutes}}</text>
              <text class="wait-suf">分钟</text>
            </view>
            <text wx:else class="wait-single">{{item.etaText}}</text>
          </view>
        </view>
        <view wx:else class="queue-status state-{{item.queueStateKind}}">
          <text class="queue-status-txt">{{item.queueStateTitle}}</text>
        </view>
      </view>

      <view class="foot-note">
        <text class="foot-note-txt">请留意叫号通知，避免错过您的号码</text>
      </view>
    </view>
    <view class="list-tail" />
  </scroll-view>
</view>
