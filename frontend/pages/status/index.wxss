/* status.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
  padding-top: 40rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #666;
}

.status-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.status-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.status-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.actions {
  margin-bottom: 40rpx;
}

.btn {
  width: 100%;
  height: 80rpx;
  font-size: 32rpx;
  border-radius: 40rpx;
  margin: 0 0 20rpx 0;
}

.primary-btn {
  background-color: #1989fa;
  color: #fff;
}

.secondary-btn {
  background-color: #fff;
  color: #1989fa;
  border: 1rpx solid #1989fa;
}

.tips {
  background-color: #f0f9ff;
  border-radius: 12rpx;
  padding: 30rpx;
  border-left: 8rpx solid #1989fa;
}

.tip-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.tip-content {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
}