.page {
  min-height: 100vh;
  padding-bottom: 48rpx;
  background-color: #ededed;
  box-sizing: border-box;
}

.group {
  margin-top: 24rpx;
  background-color: #fff;
}

.group:first-child {
  margin-top: 0;
}

.cell {
  padding: 24rpx 32rpx;
  font-size: 34rpx;
}

.cell-input-row {
  display: flex;
  align-items: center;
}

.cell-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cell-bd {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  min-height: 48rpx;
}

.cell-value {
  text-align: right;
}

.cell-value.is-ph {
  color: #888;
}

.cell-value.is-on {
  color: #000;
}

.cell-accessory {
  margin-left: 8rpx;
  color: #c7c7cc;
  font-size: 36rpx;
  line-height: 1;
}

.cell-title {
  color: #000;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.cell-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  font-size: 34rpx;
}

.cell-btn-mini {
  margin-left: 16rpx;
  flex-shrink: 0;
}

.footer {
  margin: 48rpx 32rpx 0;
}

.footer button[type="primary"] {
  width: 100%;
}

.result-card {
  margin: 48rpx 32rpx 0;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.result-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.result-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: bold;
  margin-right: 16rpx;
}

.result-header.success .result-icon {
  background: #f6ffed;
  color: #52c41a;
}

.result-header.error .result-icon {
  background: #fff2f0;
  color: #ff4d4f;
}

.result-title {
  font-size: 36rpx;
  font-weight: 600;
}

.result-header.success .result-title {
  color: #52c41a;
}

.result-header.error .result-title {
  color: #ff4d4f;
}

.result-header.neutral .result-icon {
  background: #f5f5f5;
  color: #666;
}

.result-header.neutral .result-title {
  color: #666;
}

.result-info {
  padding-top: 16rpx;
  border-top: 1rpx solid #eee;
}

.result-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.result-label {
  color: #888;
  font-size: 28rpx;
}

.result-value {
  font-size: 30rpx;
  color: #333;
}

.result-value.num {
  font-weight: 600;
  color: #1677ff;
}

.result-value.st-waiting {
  color: #1677ff;
}

.result-value.st-claimed {
  color: #d48806;
}

.result-value.st-called {
  color: #389e0d;
}

.result-value.mono {
  font-size: 24rpx;
  word-break: break-all;
  text-align: right;
  max-width: 70%;
}

.result-error {
  padding-top: 16rpx;
  border-top: 1rpx solid #eee;
  color: #ff4d4f;
  font-size: 28rpx;
  text-align: center;
}

.result-msg {
  padding-top: 16rpx;
  border-top: 1rpx solid #eee;
  font-size: 28rpx;
  text-align: center;
  line-height: 1.5;
}

.result-msg.is-muted {
  color: #666;
}

.result-msg.is-error {
  color: #ff4d4f;
}