# 微信小程序配置
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret

# 微信小程序消息模板ID
WECHAT_TEMPLATE_REMINDER_5=Ahead5ReminderTemplateId
WECHAT_TEMPLATE_CALLED=k-yabn5Ze0mYwfviBKmPDztWx6BqQynM-oGuzlyPQGY
WECHAT_TEMPLATE_QUEUE_REMINDER=5C3ru9yrICuvAAR3Evtnqn5OFD-cE7RaD9JeXUmZYK8
WECHAT_TEMPLATE_MISSED=MissedTemplateId

# 订阅消息下发 miniprogram_state：与「当前打开小程序的版本」一致。
# 真机扫体验版码 / 开发版调试须设为 trial 或 developer，否则接口成功但用户收不到。
# 仅已上架正式版小程序可省略（默认 formal）。
WECHAT_MINIPROGRAM_STATE=trial

# 服务器配置
PORT=3000
